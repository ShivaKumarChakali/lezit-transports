# Server Configuration
PORT=5001
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/lezit-transports?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRE=7d

# Email Configuration - Choose ONE: smtp (Zoho) or sendgrid
# On Render/production: use sendgrid to avoid "Connection timeout" (SMTP to Zoho is often blocked).
EMAIL_SERVICE=smtp

# Option A: Zoho Mail (SMTP) – can timeout on Render; use SendGrid there
SMTP_HOST=smtppro.zoho.in
SMTP_PORT=587
SMTP_USER_BOOKING=bookings@lezittransports.com
SMTP_PASS_BOOKING=your-booking-email-password
SMTP_USER_SUPPORT=support@lezittransports.com
SMTP_PASS_SUPPORT=your-support-email-password
EMAIL_FROM=bookings@lezittransports.com

# Option B: SendGrid (recommended for Render) – set EMAIL_SERVICE=sendgrid and add:
# SENDGRID_API_KEY=SG.your_api_key_here
# SENDGRID_FROM_EMAIL=bookings@lezittransports.com
# SENDGRID_TO_EMAIL=support@lezittransports.com

# Tracking recipient for booking emails (receives same email as customer directly in TO field)
# Both customer and this email will receive the booking confirmation/cancellation
# Default: bookings@lezittransports.com
# EMAIL_BCC_BOOKINGS=bookings@lezittransports.com

# Zoho Mail API Configuration (Optional - for OAuth token authentication)
# If these are set, they will be used for API-based email delivery
# ZOHO_CLIENT_ID=your-zoho-client-id
# ZOHO_CLIENT_SECRET=your-zoho-client-secret
# ZOHO_REFRESH_TOKEN=your-zoho-refresh-token

# Payment Configuration (for future use)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Cloud Storage (for future use)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Backend URL (for OAuth callbacks - must match Google/Facebook redirect URIs)
# Development: http://localhost:5001
# Production: https://lezit-transports-backend.onrender.com
BACKEND_URL=http://localhost:5001
